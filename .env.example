# Copy this file to .env and fill in values.
# .env is git-ignored — never commit real secrets.

# wttr.in needs no key, so nothing is required for the weather feature.
# If you switch to OpenWeatherMap, add your key here:
# WEATHER_API_KEY=your_key_here

# Backend URL used by the React frontend during local development
VITE_API_URL=http://localhost:8000
